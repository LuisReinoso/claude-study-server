# Claude Study Server — environment configuration
#
# Copy this file to `.env` and fill in the values for your setup.
# `.env` is gitignored so your token is never committed.

# Port the HTTP server binds to. Change if 3457 is taken.
STUDY_SERVER_PORT=3457

# Claude Code OAuth token used by the Claude Agent SDK.
# Get one by running `claude auth` (or from your existing Claude Code install).
# The SDK reads this env var directly — do not commit it.
CLAUDE_CODE_OAUTH_TOKEN=

# OPTIONAL: if you keep your token under a custom variable name
# (e.g. CLAUDE_CODE_OAUTH_TOKEN_PERSONAL for a per-profile setup), set
# CLAUDE_STUDY_TOKEN_VAR to that name and the server will map it into
# CLAUDE_CODE_OAUTH_TOKEN at startup. Leave blank if you just set
# CLAUDE_CODE_OAUTH_TOKEN above.
# CLAUDE_STUDY_TOKEN_VAR=CLAUDE_CODE_OAUTH_TOKEN_PERSONAL
